<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ظل خارجي -->
    <item android:top="1dp" android:bottom="3dp" android:start="1dp" android:end="3dp">
        <shape android:shape="oval">
            <solid android:color="#30000000" />
        </shape>
    </item>
    <!-- الحلقة الأساسية -->
    <item android:top="2dp" android:bottom="2dp" android:start="2dp" android:end="2dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#C084FC"
                android:centerColor="#8B5CF6"
                android:endColor="#5B21B6"
                android:angle="315" />
            <stroke
                android:width="1.5dp"
                android:color="#D8B4FE" />
        </shape>
    </item>
    <!-- لمعان داخلي -->
    <item android:top="9dp" android:bottom="20dp" android:start="9dp" android:end="20dp">
        <shape android:shape="oval">
            <solid android:color="#20FFFFFF" />
        </shape>
    </item>
</layer-list>